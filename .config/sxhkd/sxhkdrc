#
# wm independent hotkeys
#

# Reloads sxhkd configuration
super + Escape
  keeb-reset

~button3
  xqp 0 $(xdo id -N Bspwm -n root) && jgmenu_run 

# ~button9
#   blend-swap
#
# ~button2
#   blend-swap

super + k
  sxhkd-cheat

# Launch Terminal
super + Return 
  xfce4-terminal

# Toggle Conkeww
super + shift + e
  toggle-conkeww

# GUI System monitor
ctrl + shift + Escape
  gnome-system-monitor

# Rofi app launcher
alt + F1
  key-menu    

# Launch Menus
super + {x,n,d}
  {key-power,rofi-net,$(sh ~/Scripts/Modules/runmenu.sh)}

# Record a video
# super + {KP_Multiply,KP_Subtract}
  # {record,$(giph --stop && notify-send "Stopped recording video")}

# Launch Applications
super + shift + {f,g,c,d,s,v}
  {thunar,geany,code,discord,spotify,virtualbox}

# Launch firefox
super + w
  firefox

# Randomize wallpaper
super + shift + w
  {feh --bg-fill --randomize "$HOME/Pictures/Wallpapers/"}

# Volume controls
XF86Audio{RaiseVolume,LowerVolume,Mute}
  volume{ --up, --down, --toggle}

# Brightness controls
XF86MonBrightness{Up,Down}
  brightness{ --up, --down}

# Screenshot
Print
  flameshot gui

#
# Screenshot exras
#

# Maim screenshot window
ctrl + Print
  win-shot

# Maim delayed screenshot
ctrl + shift + Print
  shot-delay

#
#
# BSPWM HOTKEYS
#
#

# Quit/Restart bspwm
super + shift + {q,r}
  bspc {quit,wm -r}

# Close and kill
super + {q,Delete}
  {bspc node -c,bspc node -c}

# Alternate between the tiled and monocle layout
super + space
  bspc node -t "~"{floating,tiled}

# Switch to tiled mode
super + KP_Subtract
  bspc node -t {floating}

# Send the newest marked node to the newest preselected node
super + y
  bspc node newest.marked.local -n newest.!automatic.local

# Swap the current node and the biggest window
super + g
	bspc node -s biggest.window

#
# state/flags
#

# Set the window state
super + {ctrl + t,f,KP_Enter}
	bspc node -t {pseudo_tiled,fullscreen,fullscreen}

# Set the node flags
super + ctrl + {m,x,z}
	bspc node -g {marked,locked,private}

# Make window sticky
super + {KP_Add}
  bspc node -g {sticky}

# Tile window
super + {KP_Delete}
  bspc node -t {tiled}

# Send the window to another edge of the screen
super + {_,shift + }{Left,Down,Up,Right}
  bspc node -{f,s} {west,south,north,east}

# Change focus to next window, including floating window
alt + {_,shift + }Tab
  bspc node -f {next.local,prev.local}

# Center currently active window
super + KP_Insert
  center-window
 
#
# focus/swap
#

# Focus the node in the given direction
super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# Focus the node for the given path jump
super + {p,b,comma,period}
	bspc node -f @{parent,brother,first,second}

# Focus the next/previous window in the current desktop
super + {_,shift + }c
	bspc node -f {next,prev}.local.!hidden.window
        
# Rotate windows
super + {r,KP_Divide}        
  bspc node @/ -R {90,90}

# Focus the next/previous desktop in the current monitor
super + bracket{left,right}
	bspc desktop -f {prev,next}.local

# Focus the last node/desktop
super + {grave,Tab}
	bspc {node,desktop} -f last

# Focus the older or newer node in the focus history
super + {o,i}
	bspc wm -h off; \
	bspc node {older,newer} -f; \
	bspc wm -h on

# Focus or send to the given desktop
super + {_,shift + }{KP_End,KP_Down,KP_Next,KP_Left,KP_Begin,KP_Right,KP_Home}
	bspc {desktop -f,node -d} '^{1-7}'

#
# preselect
#

# Preselect the direction
super + alt + {KP_End,KP_Down,KP_Begin,KP_Next}
	bspc node -p {west,south,north,east}

# Preselect the ratio
super + ctrl + {1-9}
	bspc node -o 0.{1-9}

# Cancel the preselection for the focused node
super + alt + space
	bspc node -p cancel

# Cancel the preselection for the focused desktop
super + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

#
# move/resize
#

# Expanding windows
super + alt + {Left,Right,Up,Down}
  bspc node -z {left -20 0,right 20 0,top 0 -20,bottom 0 20}

# Shrinking windows
super + ctrl + {Left,Right,Up,Down}
  bspc node -z {left 20 0,right -20 0,top 0 20,bottom 0 -20}

# Move a floating window
super + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}
