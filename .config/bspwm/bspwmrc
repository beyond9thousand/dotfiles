#! /bin/sh

# Restore wallpaper
bash "$HOME"/.config/bspwm/.fehbg &

# xrdb -merge ~/.Xresources

# Starting SXHKD Keyboard Daemon
pgrep -x sxhkd > /dev/null || sxhkd & 

# Launching polybar
bash "$HOME"/.config/bspwm/polybar/launch.sh &

# xmodmap ~/.xmodmap

# pgrep -x screensaver > /dev/null || screensaver &

# pgrep -x keyled > /dev/null || keyled &

# Set configurations
for i in "$HOME"/.config/bspwm/configs/*.sh; do {
  eval "$i" & 
} 
done

# fix pointer
xsetroot -cursor_name left_ptr &

# Set rules
for i in "$HOME"/.config/bspwm/rules/*.sh; do {
  eval "$i" & 
} 
done

## Autostart

# Kill if already running
killall -9 picom sxhkd dunst xfce4-power-manager ksuperkey \
eww copyq flameshot playerctld touchegg \
pavucontrol green-tunnel jgmenu

# Launch Conkeww
#sed -i "s/colors\/color-.*/colors\/color-tokyo.yuck\")/g" "$HOME"/.config/conkeww/eww.yuck
#eww --config "$HOME"/.config/conkeww/ open conkeww-main

# Launch notification daemon
# dunst -config "$HOME"/.config/bspwm/dunstrc & 

# Enable Super Keys For Menu
ksuperkey -e 'Super_L=Alt_L|F1' &
ksuperkey -e 'Super_R=Alt_L|F1' &

# polkit agent
if [[ ! `pidof xfce-polkit` ]]; then
    /usr/lib/xfce-polkit/xfce-polkit & 
fi

# Enable power management
xfce4-power-manager & 

# Start copyq and flameshot
copyq --start-server & 
flameshot & 

# Start playerctld daemon to monitor playback
playerctld daemon &

# Begin touchpad swipe control
touchegg & 

# Launch pavucontrol
pavucontrol & 

# Active green-tunnel
pkill -9 -f "green-tunnel"
green-tunnel &

# start compositor
while pgrep -u $UID -x picom >/dev/null; do sleep 1; done
picom --config "$HOME"/.config/bspwm/picom.conf &

# replace neovim colorscheme
sed -i "s/theme =.*$/theme = \"tokyonight\",/g" "$HOME"/.config/nvim/lua/custom/chadrc.lua

# change cava colorscheme
# CAVA_PATH=""$HOME"/.config/cava"
# cp "$CAVA_PATH"/colorschemes/tokyo-night "$CAVA_PATH"/config

# Delete existing hooks and restart them
for i in "$HOME"/.config/bspwm/hooks/*.sh; do {
  pkill -9 -f "$i" 
  eval "$i" &
} 
done

# sleep 5 && xmodmap ~/xmodmap.old
